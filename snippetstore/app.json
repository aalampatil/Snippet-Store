{
  "expo": {
    "name": "snippetstore",
    "slug": "snippetstore",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/expo.icon/Assets/grid.png",
    "scheme": "snippetstore",
    "userInterfaceStyle": "dark",
    "androidStatusBar": {
      "backgroundColor": "#00000000",
      "barStyle": "dark-content",
      "translucent": true
    },
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "adaptiveIcon": {
        "backgroundColor": "#0e0e0e",
        "foregroundImage": "./assets/expo.icon/Assets/grid.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.aalampatil.snippetstore"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/expo.icon/Assets/grid.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0e0e0e",
          "android": {
            "image": "./assets/expo.icon/Assets/grid.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "60d7f7d6-5621-4362-b057-339b9cb69901"
      }
    }
  }
}
